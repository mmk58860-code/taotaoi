[Unit]
Description=TAO Ecosystem Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=taomonitor
Group=taomonitor
WorkingDirectory=/opt/tao-monitor
EnvironmentFile=/opt/tao-monitor/.env
ExecStart=/opt/tao-monitor/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

